-  <os>
-    <type arch='x86_64' machine='pc-i440fx-10.0'>hvm</type>
-    <loader readonly='no' type='rom' format='raw'>/usr/share/seabios/bios.bin</loader>
-    <boot dev='hd'/>
-  </os>
-  <cpu mode='custom' match='exact' check='none'>
-    <model fallback='forbid'>qemu64</model>
