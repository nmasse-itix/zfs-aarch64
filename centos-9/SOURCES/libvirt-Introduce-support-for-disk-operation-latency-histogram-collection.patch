 src/conf/domain_conf.c                        | 133 +++++++++++++++++-
 src/conf/domain_conf.h                        |   7 +
 src/conf/schemas/domaincommon.rng             |  37 ++++-
 ...isk-statistics-intervals.x86_64-latest.xml |  29 ++++
 .../disk-statistics-intervals.xml             |  25 ++++
